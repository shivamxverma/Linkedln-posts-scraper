datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

model Job {
  id        String   @id @default(cuid())
  source    String // e.g. "wellfound"
  title     String
  company   String
  location  String
  salary    String?
  applyUrl  String   @unique // Prevents duplicate listings
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([source])
  @@index([company])
}
